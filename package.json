{
  "name": "rends",
  "version": "0.8.2",
  "description": "RenDS — A vanilla, accessible, atomic design system. No framework required.",
  "author": "Ren",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rensoconese/ren10.git"
  },
  "homepage": "https://github.com/Rensoconese/ren10#readme",
  "type": "module",
  "main": "index.css",
  "bin": {
    "rends": "./cli/index.js"
  },
  "files": [
    "index.css",
    "tokens/",
    "base/",
    "components/",
    "utils/",
    "cli/",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "import": "./index.css"
    },
    "./components/*": {
      "import": "./components/*.js"
    },
    "./tokens/*": {
      "import": "./tokens/*.css"
    },
    "./base/*": {
      "import": "./base/*.css"
    },
    "./utils": {
      "import": "./utils/index.js"
    }
  },
  "sideEffects": [
    "*.css",
    "./components/**/*.js"
  ],
  "scripts": {
    "lint:css": "stylelint 'components/**/*.css' 'base/**/*.css' 'tokens/**/*.css'",
    "lint:js": "eslint 'components/**/*.js' 'utils/**/*.js' 'cli/**/*.js'",
    "lint": "npm run lint:css && npm run lint:js",
    "test": "playwright test",
    "test:a11y": "playwright test --config tests/a11y/playwright.config.cjs",
    "test:visual": "playwright test --config tests/visual/playwright.config.cjs",
    "test:components": "playwright test --config tests/components/playwright.config.cjs"
  },
  "keywords": [
    "design-system",
    "css",
    "web-components",
    "accessible",
    "vanilla",
    "a11y",
    "tokens"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "axe-core": "^4.11.4",
    "axe-playwright": "^2.2.2"
  }
}
